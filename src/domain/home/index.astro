---
import Layout from 'layouts/default.astro'
import Header from './components/header/index.astro'
import Hero from './components/hero/index.astro'
import Features from './components/features/index.astro'
import Code from './components/code/index.astro'
import Cta from './components/cta/index.astro'
import Footer from './components/footer/index.astro'
---

<Layout>
	<Fragment slot="content">
		<Header />
		<Hero />
		<Features />
		<Code />
		<Cta />
		<Footer />
	</Fragment>
</Layout>

<!-- Custom Styles -->
<style is:global>
	:root {
		--background: 0, 0%, 100%;
		--foreground: 215, 25%, 15%;
		--card: 210, 20%, 98%;
		--card-foreground: 215, 25%, 15%;
		--primary: 210, 71%, 42%;
		--primary-foreground: 0, 0%, 100%;
		--secondary: 210, 20%, 95%;
		--muted: 210, 15%, 93%;
		--muted-foreground: 215, 15%, 45%;
		--border: 210, 15%, 90%;
	}

	body {
		color: hsl(var(--foreground));
		background-color: hsl(var(--background));
	}
	
	/* Gradient text */
	.text-gradient {
		background: linear-gradient(135deg, hsl(210, 71%, 42%), hsl(210, 71%, 52%));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	/* Code window styling */
	.code-window {
		border: 1px solid hsl(var(--border));
		border-radius: 0.75rem;
		background-color: hsl(var(--card));
	}

	.in-view.slide-in-left {
		animation: slide-in-left 0.5s ease-out;
	}

	.in-view.slide-in-right {
		animation: slide-in-right 0.5s ease-out;
	}

	/* Intersection Observer animations */
	scroll-animate {
		opacity: 0;
		transform: translateY(20px);
	}

	scroll-animate.in-view {
		opacity: 1;
		transform: translateY(0);
		transition: opacity 0.5s ease-out, transform 0.5s ease-out;
	}

	/* Slide in animation for code section */
	@keyframes slide-in-left {
		from {
			opacity: 0;
			transform: translateX(-30px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	@keyframes slide-in-right {
		from {
			opacity: 0;
			transform: translateX(30px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

</style>