---

---

<script>
	import { register } from 'shared/main'
	import * as appHero from './index'
	register('app-hero', appHero)
</script>

<app-hero class="relative flex min-h-screen items-center justify-center overflow-hidden">
	
	<div class="hero-glow absolute inset-0"></div>
	
	<div class="absolute top-1/4 left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-blue-500/5 blur-3xl animate-pulse-glow"></div>

	<div class="container relative z-10 mx-auto px-6 py-24 text-center">

		<!-- Title -->
		<h1 class="fade-in fade-in-delay-1 mx-auto max-w-4xl text-5xl leading-tight tracking-tight md:text-7xl">
			An Elegant and <br />
			<span class="text-gradient"> Minimalistic</span>
			<br />
			Micro-Framework
		</h1>

		<!-- Subtitle -->
		<p class="fade-in fade-in-delay-2 mx-auto mt-6 max-w-2xl text-lg text-gray-600 md:text-xl">
			Build interactive web applications with <strong>Web Components</strong>, Island Architecture and the power of functional JavaScript.
			<br />
			<strong class="font-bolder text-gradient">Simple, Fast, and Lightweight.</strong>
		</p>
		
		<!-- CTA buttons -->
		<div class="fade-in fade-in-delay-3 mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
			<a href="https://jails-js.org/about/"
				target="_blank"
				class="inline-flex items-center gap-2 rounded-xl bg-[#2e85dc] px-6 py-3 text-base font-semibold text-white transition-all hover:opacity-90 hover:shadow-lg hover:shadow-blue-500/25">
				Get Started
				<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
				</svg>
			</a>
			<a href="https://github.com/jails-org" target="_blank" rel="noopener noreferrer"
				class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-gray-50 px-6 py-3 text-base font-medium text-gray-900 transition-colors hover:bg-gray-100">
				View on GitHub
			</a>
		</div>

		<!-- Install command -->
		<div class="fade-in fade-in-delay-4 mx-auto mt-12 max-w-md">
			<button data-copy-paste class="code-window flex w-full items-center justify-between px-5 py-3.5 font-mono text-sm transition-all hover:border-blue-500/50">
				<span>
					<span class="text-gray-600">$ </span>
					<span class="text-gray-900" id="install-cmd">npm install jails-js</span>
				</span>
				<svg class="h-5 w-5 text-gray-600" id="copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
				</svg>
			</button>
		</div>
	</div>
</app-hero>

<style>

	.animate-pulse-glow {
		animation: pulse-glow 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
	}

	/* Hero glow background */
	.hero-glow {
		background: radial-gradient(
			ellipse at center,
			hsl(210, 71%, 42%, 0.15) 0%,
			transparent 70%
		);
	}

	.fade-in {
		animation: fade-in 0.6s ease-out;
	}

	.fade-in-delay-1 { animation-delay: 0.1s; }
	.fade-in-delay-2 { animation-delay: 0.2s; }
	.fade-in-delay-3 { animation-delay: 0.3s; }
	.fade-in-delay-4 { animation-delay: 0.4s; }

	/* Fade-in animation */
	@keyframes fade-in {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Hero glow animation */
	@keyframes pulse-glow {
		0%, 100% { opacity: 0.3; }
		50% { opacity: 0.6; }
	}

</style>