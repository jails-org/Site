<!-- CTA Section -->
<section class="relative border-t border-gray-200/50 py-24">
	<div class="hero-glow absolute inset-0 opacity-50"></div>
	<div class="container relative z-10 mx-auto px-6 text-center">
		<scroll-animate class="block">
			<h2 class="text-3xl font-bold md:text-5xl text-gray-900">
				Ready to build with
				<span class="text-gradient"> Jails.js</span>?
			</h2>
			<p class="mx-auto mt-4 max-w-lg text-lg text-gray-600">
				Start building elegant web applications with the simplicity of functional JavaScript and Web Components.
			</p>
			<div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
				<a href="https://jails-js.org/about/"
					target="_blank"
					class="inline-flex items-center gap-2 rounded-xl bg-[#2e85dc] px-6 py-3 text-base font-semibold text-white transition-all hover:opacity-90 hover:shadow-lg hover:shadow-blue-500/25">
					Get Started
					<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
					</svg>
				</a>
			</div>
		</scroll-animate>
	</div>
</section>